      "highlighter": "auto",
      "textmate_grammar": null,
      "show_whitespace_tabs": true,
      "use_tabs": true,
      "tab_size": 4,
      "on_save": []
    },
    "fish": {
      "extensions": ["fish"],
      "grammar": "",
      "comment_prefix": "#",
      "auto_indent": true,
      "highlighter": "auto",
      "textmate_grammar": null,
      "show_whitespace_tabs": true,
      "use_tabs": true,
