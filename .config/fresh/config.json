    "just": {
      "command": "just-lsp",
      "args": [],
      "enabled": true,
      "auto_start": false,
      "process_limits": {
        "max_memory_percent": 50,
        "max_cpu_percent": 90,
        "enabled": true
      },
      "initialization_options": null
    },
    "odin": {
      "command": "ols",
      "args": [],
      "enabled": true,
      "auto_start": false,
      "process_limits": {
        "max_memory_percent": 50,
        "max_cpu_percent": 90,
        "enabled": true
      },
      "initialization_options": {
        "enable_hover": true,
        "enable_snippets": true,
        "enable_semantic_tokens": true,
        "enable_document_symbols": true,
        "collections": [
          {
            "name": "base",
