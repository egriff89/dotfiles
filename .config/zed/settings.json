// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "show_edit_predictions": true,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 12.0,
  "ui_font_size": 13,
  "ui_font_family": "JetBrainsMono Nerd Font",
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Tokyo Night Storm",
  },
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "default_profile": "write",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-haiku-4-5-latest",
    },
    "model_parameters": [],
  },
  "languages": {
    "Python": {
      "language_servers": ["ty", "!basedpyright", "!python-lsp-server"],
    },
  },
  "lsp": {
    "ols": {
      "initialization_options": {
        "enable_hover": true,
        "enable_snippets": true,
        "enable_procedure_snippet": true,
        "enable_completion_matching": true,
        "enable_references": true,
        "enable_document_symbols": true,
        "enable_format": true,
        "enable_document_links": true,
        "collections": [
          {
            "name": "base",
            "path": "/home/eric/.local/share/Odin/base",
          },
          {
            "name": "core",
            "path": "/home/eric/.local/share/Odin/core",
          },
          {
            "name": "shared",
            "path": "/home/eric/.local/share/Odin/shared",
          },
          {
            "name": "vendor",
            "path": "/home/eric/.local/share/Odin/vendor",
          },
        ],
      },
      "binary": {
        "path": "/home/eric/.local/bin/ols",
      },
    }, // ols
    "ocamllsp": {
      "settings": {
        "inlayHints": {
          "hintFunctionParams": true,
          "hintPatternVariables": true,
          "hintLetBindings": true,
        },
        "syntaxDocumentation": true,
      },
    },
  },
}
