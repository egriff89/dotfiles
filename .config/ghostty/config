# ~/.config/ghostty/config
# Author: Eric Griffith
# https://gitlab.com/egriff89

### Theme and fonts
theme = TokyoNight Storm
font-family = JetBrainsMono Nerd Font
font-size = 9

### Disable GTK titlebar
gtk-titlebar = false

### Window settings
window-theme = system
window-inherit-font-size = false
window-padding-x = 4

### Keybinds
keybind = ctrl+t=new_tab
keybind = ctrl+]=next_tab
keybind = ctrl+[=previous_tab

## Splits
keybind = shift+ctrl+left=new_split:left
keybind = shift+ctrl+down=new_split:down
keybind = shift+ctrl+up=new_split:up
keybind = shift+ctrl+right=new_split:right

keybind = shift+ctrl+alt+left=goto_split:left
keybind = shift+ctrl+alt+down=goto_split:bottom
keybind = shift+ctrl+alt+up=goto_split:top
keybind = shift+ctrl+alt+right=goto_split:right
